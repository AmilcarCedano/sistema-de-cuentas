# ── Base de datos MySQL ──
MYSQL_ROOT_PASSWORD=cambia_esta_password_segura
MYSQL_DATABASE=sistema_cuentas

# ── Google Gemini (plan gratuito AI Studio) ──
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AQ.tu_clave_aqui

# ── WAHA (WhatsApp HTTP API) ──
# En VPS: WAHA corre en el host → usar host.docker.internal
WAHA_URL=http://host.docker.internal:3000
WAHA_API_KEY=tu_api_key_de_waha

# ── ID del grupo de WhatsApp que se monitorea ──
# Obtenerlo en WAHA Dashboard → sesión → grupos
# Formato: 120363XXXXXXXXXX@g.us
WAHA_GROUP_ID=120363429021154118@g.us

# ── Credenciales UPAO (cuenta por defecto del scraper) ──
UPAO_USER=TU_ID_UPAO
UPAO_PASS=TU_NIP_UPAO
